# Standalone TriggerToDo only.
# FengDock production deployment does not read this file.

# App
APP_NAME=TriggerToDo Backend
DEBUG=false
DATABASE_URL=sqlite:///./triggertodo.db
SESSION_SECRET_KEY=replace-with-long-random-value
SESSION_COOKIE_NAME=triggertodo_session
FRONTEND_DIR=frontend/dist

# Trigger webhook
TRIGGER_WEBHOOK_SECRET=replace-this

# Scheduler
TRIGGER_ENGINE_INTERVAL_SECONDS=30
